<?xml version="1.0" encoding="UTF-8"?>
<!--
  smutHub sitemap — lists every public URL we want Google + Bing to index.
  Admin pages (admin.html, catalog-admin.html) are intentionally excluded
  and are also blocked in robots.txt.

  Update lastmod when you ship meaningful content changes to a page.
  When per-book and per-trope landing pages come online, append them here
  (or switch to a sitemap index that splits books and tropes into their own
  child sitemaps once we cross ~1k URLs).
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://smuthub.ca/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://smuthub.ca/smuthub-app.html</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://smuthub.ca/dashboard.html</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://smuthub.ca/smuthub-bookcase.html</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>https://smuthub.ca/stores.html</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <url>
    <loc>https://smuthub.ca/sitemap.html</loc>
    <changefreq>monthly</changefreq>
